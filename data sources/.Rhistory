# unpack the dataset
houses <- mosaicData::SaratogaHouses
houses <- houses |> mutate(logPrice = log(price))
# Min(Price) = 5000 looks quite suspicious, will look into that
houses |> filter(price < 50000) |> arrange(price)
# Ok, so since the houses are all (relatively) new, they should be adding to the land value.
# Therefore, these observations are errors in the dataset and should be removed
houses_filtered <- houses |> filter(price > landValue)
# looks very linear now
# will include logAge as predictor, excluding 0's (since they will be captured by newConstruction anyway it doesn't matter)
houses_filtered <- houses_filtered |>
mutate(logAge = ifelse(age > 0, log(age), 0))
library(ggplot2)
# clear right skew, so log price for sure
library(tidyverse)
houses <- houses |> mutate(logPrice = log(price))
# Ok, so since the houses are all (relatively) new, they should be adding to the land value.
# Therefore, these observations are errors in the dataset and should be removed
houses_filtered <- houses |> filter(price > landValue)
# looks very linear now
# will include logAge as predictor, excluding 0's (since they will be captured by newConstruction anyway it doesn't matter)
houses_filtered <- houses_filtered |>
mutate(logAge = ifelse(age > 0, log(age), 0))
# landValue should absolutely have a linear relationship to price
plot(houses_filtered$landValue, houses_filtered$logPrice, xlab="Land Value ($)", ylab="LogPrice log($)")
# plot looks better now, removed the obvious non-linear effect
# But middle is far lower than I would've thought, maybe confounding variables pulling it down?
# Unclear, but I think I will go with log(landValue) for the first model, and then check the component residual plot for it
# effect should be linear, landValue + $1 = price + $1
houses_filtered <- houses_filtered |> mutate(logLandValue = log(landValue))
# middle a little lower than expected here too, same as before, perhaps confounding variables pulling it down slightly
# Will go for log(livingArea) for the first model, then check the crPlot for it
houses_filtered <- houses_filtered |> mutate(logLivingArea = log(livingArea))
# What about interactions with landValue and pctCollege, I think that having a higher percentage of college grads might make price higher in areas with already high land values
houses_filtered$pctCollegeBin <- cut(houses_filtered$pctCollege,
breaks = c(0, 40, 60, 80),
labels = c("Low", "Mid", "High"), include.lowest = TRUE)
ggplot(houses_filtered, aes(x = logLandValue, y = logPrice, color = pctCollegeBin)) +
geom_point(alpha = 0.3) +
geom_smooth(method = "loess")
# I think that logLivingArea, bedrooms, bathrooms, and rooms will be highly correlated.
# Especially rooms and logLivingArea, since we are depending on logLivingArea for the interaction effect, I am inclined to remove rooms
# Though I want to keep rooms, as I think it gives more information that bed and bath
# So I am inclined to remove bedrooms
# And logLivingArea too?
ggplot(houses_filtered, aes(x = rooms, y = logPrice, color = centralAir)) +
geom_point() +
geom_smooth(method = "loess")
# I think that looks good, ready to build the model now
saratoga_houses_lm1 <- lm(logPrice ~ lotSize + logLandValue + logAge + logLivingArea + pctCollege + fireplaces + bathrooms +
heating + sewer + waterfront + newConstruction + centralAir + centralAir*logLivingArea, data = houses_filtered)
summary(saratoga_houses_lm1)
# removing fireplace
saratoga_houses_lm3 <- lm(logPrice ~ lotSize + logLandValue + logAge + logLivingArea + pctCollege + bathrooms +
heating + waterfront + newConstruction + centralAir + centralAir*logLivingArea, data = houses_filtered)
summary(saratoga_houses_lm3)
car::vif(saratoga_houses_lm3)
car::vif(saratoga_houses_lm3, type = "predictor")
saratoga_houses_lm4_check <- lm(logPrice ~ lotSize  + logAge + logLivingArea + pctCollege + bathrooms +
heating + waterfront + newConstruction + centralAir + centralAir*logLivingArea, data = houses_filtered)
summary(saratoga_houses_lm4)
summary(saratoga_houses_lm4_check)
homeless <- mosaicData::HELPrct
View(homeless)
help_data <- mosaicData::HELPrct %>%
select(homeless, age, cesd, d1, female, sex, g1b, i1, i2,
indtot, mcs, pcs, pss_fr, racegrp, satreat, substance,
treat, sexrisk)
summary(help_data)
continuous_vars <- c("age", "cesd", "d1", "i1", "i2", "indtot", "mcs", "pcs", "pss_fr", "sexrisk")
for (var in continuous_vars) {
p <- ggplot(help_data, aes(x = homeless, y = .data[[var]])) +
geom_boxplot() +
ggtitle(paste("homeless vs", var))
print(p)
}
categorical_vars <- c("sex", "g1b", "racegrp", "satreat", "substance", "treat")
for (var in categorical_vars) {
p <- ggplot(help_data, aes(x = .data[[var]], fill = homeless)) +
geom_bar(position = "fill") +
ylab("proportion") +
ggtitle(paste("homeless vs", var))
print(p)
}
homeless_glm1 <- glm(homeless ~ pss_fr + indot + age + i2 + mcs + sexrisk + substance + g1b)
homeless_glm1 <- glm(homeless ~ pss_fr + indot + age + i2 + mcs + sexrisk + substance + g1b, data = help_data)
homeless_glm1 <- glm(homeless ~ pss_fr + indtot + age + i2 + mcs + sexrisk + substance + g1b, data = help_data)
help_glm1 <- glm(homeless ~ pss_fr + indtot + age + i1 + mcs + sexrisk + substance + g1b + sex,
data = help_data, family = binomial)
summary(help_glm1)
plot(help_glm1)
car::crPlots(help_glm1)
# crPlots look good, maybe slight curve at the extreme right i1, but thats driven by a few heavy drinkers, not systemic pattern
# pss_fr is positive, which is strange.
levels(help_data$homeless)
# Start by dropping mcs, (p=0.46)
help_glm2 <- glm(homeless ~ pss_fr + indtot + age + i1 + sexrisk + substance + g1b + sex,
data = help_data, family = binomial)
summary(help_glm1)
plot(help_glm1)
car::crPlots(help_glm1)
summary(help_glm2)
# Dropping age (p=0.19)
help_glm2 <- glm(homeless ~ pss_fr + indtot + i1 + sexrisk + substance + g1b + sex,
data = help_data, family = binomial)
# Dropping age (p=0.19)
help_glm3 <- glm(homeless ~ pss_fr + indtot + i1 + sexrisk + substance + g1b + sex,
data = help_data, family = binomial)
summary(help_glm3)
# dropping sex (p=0.20)
help_glm4 <- glm(homeless ~ pss_fr + indtot + i1 + sexrisk + substance + g1b,
data = help_data, family = binomial)
summary(help_glm4)
plot(help_glm4)
# dropping sex risk (p=0.16)
help_glm5 <- glm(homeless ~ pss_fr + indtot + i1 + substance + g1b,
data = help_data, family = binomial)
summary(help_glm5)
# considering dropping g1byes from model, AIC is basically unchanged (AIC: 584.7-> 584.67)
# I will keep g1byes and substance in the model, because substance is clearly relevant to homelessness from a domain point of view
# And g1byes captures a mental health dimension not covered by other predictors
# Despite their poor p-values, they are still useful to have in the model
help_glm6 <- glm(homeless ~ pss_fr + indtot + i1 + substance,
data = help_data, family = binomial)
summary(help_glm6)
# considering dropping g1byes from model, AIC is basically unchanged (AIC: 584.7-> 584.67)
# I will keep g1byes and substance in the model, because substance is clearly relevant to homelessness from a domain point of view
# And g1byes captures a mental health dimension not covered by other predictors
# Despite their poor p-values, they are still useful to have in the model
help_glm6 <- glm(homeless ~ pss_fr + indtot + i1,
data = help_data, family = binomial)
# considering dropping g1byes from model, AIC is basically unchanged (AIC: 584.7-> 584.67)
# I will keep g1byes and substance in the model, because substance is clearly relevant to homelessness from a domain point of view
# And g1byes captures a mental health dimension not covered by other predictors
# Despite their poor p-values, they are still useful to have in the model
help_glm6 <- glm(homeless ~ pss_fr + indtot + i1,
data = help_data, family = binomial)
summary(help_glm6)
# considering dropping g1byes from model, AIC is basically unchanged (AIC: 584.7-> 584.67)
# I will keep g1byes and substance in the model, because substance is clearly relevant to homelessness from a domain point of view
# And g1byes captures a mental health dimension not covered by other predictors
# Since these predictors all have domain significance, with substance type being a core feature of the population,
# and suicidal ideation captures mental health severity that other predictors don't address.
car::crPlots(help_glm5)
plot(help_glm5)
help_data[438,]
