left_join(
apartments_full %>%
filter(!is.na(vacancy_rate)) %>%
group_by(neighborhood_zip) %>%
summarise(borough_vacancy = median(vacancy_rate)),
by = "neighborhood_zip"
) %>%
mutate(
vacancy_rate = ifelse(is.na(vacancy_rate), borough_vacancy, vacancy_rate)
) %>%
select(-borough_vacancy)
