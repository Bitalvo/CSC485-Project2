# c) Use all-possible-regressions-selection to find the "best" predictors of heat rate
leaps::regsubsets(HEATRATE~0, data=GASTURBINE)
# c) Use all-possible-regressions-selection to find the "best" predictors of heat rate
leaps::regsubsets(HEATRATE~., data=GASTURBINE)
# c) Use all-possible-regressions-selection to find the "best" predictors of heat rate
bestSubsets <- leaps::regsubsets(HEATRATE~., data=GASTURBINE)
summary(bestSubsets)
summary(bestSubsets)$adjr
