# 6.10 Cooling method for gas turbines
GASTURBINE <- read.csv("GASTURBINE.csv")
head(GASTURBINE)
turbine
# y: heat rate
# x1: Engine type x1={1 if traditional, 0 if advanced}
# x2: Engine type x2={1 if aeroderivative, 0 if advanced}
# x3: # shafts
# x4: cycle speed (RPM)
# x3: cycle pressure ratio
# x4: Inlet temperature (Celsius)
# x5: Outlet temperature (Celsius)
# x6: Air mass flow rate (Kg/s)
# x7: horsepower (Hp units)
turbine_null <- lm(HEATRATE ~ 1, data=GASTURBINE)
turbine_full <- lm(HEATRATE ~ ., data=GASTURBINE)
step(turbine_null, direction = "forward", scope = list(lower=turbine_null, upper=turbine_full))
# b) Use backwards regression to find the "best" predictors of heat rate
step(turbine_full, direction="backwards")
# b) Use backwards regression to find the "best" predictors of heat rate
step(turbine_full, direction="backward")
# c) Use all-possible-regressions-selection to find the "best" predictors of heat rate
leaps::regsubsets(HEATRATE~., data=turbine_full)
# c) Use all-possible-regressions-selection to find the "best" predictors of heat rate
leaps::regsubsets(HEATRATE~., data=GASTURBINE)
# c) Use all-possible-regressions-selection to find the "best" predictors of heat rate
