navy <- read.csv("NAVALFLEET.csv")
navy_lm <- lm(IMPROVE ~ COST + I(COST^2), data=navy)
plot(navy_lm)
# QQPlot: Normality assumption appears to be fine, right most residuals are a little smaller than predicted, but error margins are wide because sample size is small n = 10, and df= n - (k + 1) = 10 - (2 + 1) = 7.
# I don't really see any trends, I do see an outlier: observation 10. It has a cooks score of 0.95, so is an influential point, with a leverage of 0.8 > 2(3) / 10 = 0.6, is high leverage
# we found that diagnostic plots for the quadratic model look mostly fine, but one fairly influential observation is included in the data. Bootstrap the standard errors for both coefficients and compare to the theoretical standard errors given by summary().
nboot = 1000
set.seed(1)
boot_model_se = numeric(nboot)
boot_b1 <- numeric(nboot)
boot_b2 <- numeric(nboot)
# we have the model, we want to sample with replacement 10 points (since nrow(navy) = 10)
# We need to repeat this 1000 times, and for each time, take the standard errors of B1, B2 and the model
# first create the sample, then create the model
# then extract and save the standard errors of the model (and predictors) to compare to summary(og)
for (i in 1:nboot)
{
boot_sample <- navy[sample(1:10, size=10, replace=TRUE), ]
boot_model <- lm(IMPROVE ~ COST + I(COST^2), data=boot_sample)
boot_b1[i] <- coef(boot_model)[2]
boot_b2[i] <- coef(boot_model)[3]
}
summary(navy_lm)
# b1, std. err. = 0.280876
# b2, std. err. = 0.001254
sd(boot_b1)
sd(boot_b2)
